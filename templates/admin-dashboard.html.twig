{% extends 'base.html.twig' %}

{% block title %}Espace administrateur{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pilot-dashboard.css">
{% endblock %}

{% block body %}
<main class="pilot-page">
    <div class="pilot-container">
        <div class="pilot-header">
            <h1>Tableau de bord Administrateur</h1>
            <p>Vue globale de la plateforme</p>
        </div>

        <section class="stats-grid">
            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ stats.offers }}</strong>
                    <span>Offres</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ stats.students }}</strong>
                    <span>Étudiants</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ stats.pilots }}</strong>
                    <span>Pilotes</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ stats.applications }}</strong>
                    <span>Candidatures</span>
                </div>
            </article>
        </section>

        <section class="quick-actions">
            <article class="action-card">
                <h3>Gestion des entreprises</h3>
                <p>Créer, modifier, évaluer, supprimer et consulter les entreprises.</p>
                <a href="/admin-entreprises" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Gestion des pilotes</h3>
                <p>Créer, modifier, supprimer et consulter les comptes pilotes.</p>
                <a href="/admin-pilotes" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Gestion des étudiants</h3>
                <p>Créer, modifier, supprimer et consulter les comptes étudiants.</p>
                <a href="/pilot-etudiants" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Gestion des offres</h3>
                <p>Accéder aux offres et aux candidatures.</p>
                <a href="/pilot-offres" class="student-button">Accéder</a>
            </article>
        </section>

        <section class="activity-section">
            <div class="activity-header">
                <h2>Étudiants récents</h2>
            </div>

            <div class="student-list">
                {% for student in recent_students %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ student.prenom }} {{ student.nom }}</h3>
                            <p>{{ student.formation }} • {{ student.email }}</p>
                            <small>Dernière activité : {{ student.last_activity|date('d/m/Y') }}</small>
                        </div>
                    </article>
                {% else %}
                    <p class="empty-state">Aucun étudiant trouvé.</p>
                {% endfor %}
            </div>
        </section>

        <section class="activity-section">
            <div class="activity-header">
                <h2>Pilotes récents</h2>
            </div>

            <div class="student-list">
                {% for pilot in recent_pilots %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ pilot.prenom }} {{ pilot.nom }}</h3>
                            <p>{{ pilot.email }}</p>
                        </div>
                    </article>
                {% else %}
                    <p class="empty-state">Aucun pilote trouvé.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</main>
{% endblock %}