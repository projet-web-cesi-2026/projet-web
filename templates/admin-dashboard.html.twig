{% extends 'base.html.twig' %}

{% block title %}Tableau de bord Administrateur{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/admin-dashboard.css">
{% endblock %}

{% block body %}
<main class="admin-dashboard-page">
    <h1 class="admin-dashboard-title">Tableau de bord Administrateur</h1>
    <p class="admin-dashboard-subtitle">Vue globale de la plateforme</p>

    <section class="admin-stats-grid">
        <article class="admin-stat-card">
            <strong>{{ offers_count }}</strong>
            <span>Offres</span>
        </article>

        <article class="admin-stat-card">
            <strong>{{ students_count }}</strong>
            <span>Étudiants</span>
        </article>

        <article class="admin-stat-card">
            <strong>{{ pilots_count }}</strong>
            <span>Pilotes</span>
        </article>

        <article class="admin-stat-card">
            <strong>{{ applications_count }}</strong>
            <span>Candidatures</span>
        </article>
    </section>

    <section class="admin-actions-grid">
        <article class="admin-action-card">
            <div>
                <h2>Gestion des entreprises</h2>
                <p>Créer, modifier, évaluer, supprimer et consulter les entreprises.</p>
            </div>
            <a href="/admin-entreprises" class="admin-action-button">Accéder</a>
        </article>

        <article class="admin-action-card">
            <div>
                <h2>Gestion des pilotes</h2>
                <p>Créer, modifier, supprimer et consulter les comptes pilotes.</p>
            </div>
            <a href="/admin-pilotes" class="admin-action-button">Accéder</a>
        </article>

        <article class="admin-action-card">
            <div>
                <h2>Gestion des étudiants</h2>
                <p>Créer, modifier, supprimer et consulter les comptes étudiants.</p>
            </div>
            <a href="/admin-etudiants" class="admin-action-button">Accéder</a>
        </article>

        <article class="admin-action-card">
            <div>
                <h2>Gestion des offres</h2>
                <p>Accéder aux offres et aux candidatures.</p>
            </div>
            <a href="/admin-offres" class="admin-action-button">Accéder</a>
        </article>

        <article class="admin-action-card">
            <div>
                <h2>Gestion des promotions</h2>
                <p>Créer, modifier, supprimer et gérer les promotions par année.</p>
            </div>
            <a href="/admin-promotions" class="admin-action-button">Accéder</a>
        </article>

        <article class="admin-action-card">
            <div>
                <h2>Statistiques des offres</h2>
                <p>Consulter les indicateurs clés dans une page dédiée avec carrousel.</p>
            </div>
            <a href="/statistiques-offres" class="admin-action-button">Accéder</a>
        </article>
    </section>

    <section class="admin-recent-section">
        <h2>Étudiants récents</h2>

        <div class="admin-student-list">
            {% for student in recent_students %}
                <article class="admin-student-row">
                    <h3>{{ student.prenom }} {{ student.nom }}</h3>
                    <p>{{ student.formation }} • {{ student.email }}</p>
                    <small>Dernière activité : {{ student.last_activity|date('d/m/Y') }}</small>
                </article>
            {% else %}
                <p class="admin-empty">Aucun étudiant récent.</p>
            {% endfor %}
        </div>
    </section>
</main>
{% endblock %}