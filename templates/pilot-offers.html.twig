{% extends 'base.html.twig' %}

{% block title %}Gestion des offres{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pilot-dashboard.css">
{% endblock %}

{% block body %}
<main class="pilot-page">
    <div class="pilot-container">
        <section class="activity-section">
            <div class="activity-header">
                <h2>Gestion des offres</h2>
                <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                    <a href="/pilot-offre-create" class="student-button">Créer une offre</a>
                    {% if current_user.role == 'administrateur' %}
                        <a href="/espace-admin">Retour au dashboard</a>
                    {% else %}
                        <a href="/espace-pilote">Retour au dashboard</a>
                    {% endif %}
                </div>
            </div>

            <div class="student-list">
                {% for offer in offers %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ offer.titre }}</h3>
                            <p>{{ offer.entreprise_nom ?: 'Entreprise non définie' }} • {{ offer.lieu }}</p>
                            <small>
                                {{ offer.duree_semaines }} semaines • {{ offer.remuneration }} € • publiée le {{ offer.created_at|date('d/m/Y') }}
                            </small>
                        </div>

                        <div class="student-actions student-actions-vertical">
                            <a href="/offres/{{ offer.id }}" class="student-button">Voir</a>
                            <a href="/pilot-offres/{{ offer.id }}/editer" class="student-button">Modifier</a>

                            <form method="POST" action="/pilot-offres/{{ offer.id }}/supprimer" onsubmit="return confirm('Confirmer la suppression ?');">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="student-button">Supprimer</button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    <p class="empty-state">Aucune offre trouvée.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</main>
{% endblock %}