{% extends 'base.html.twig' %}

{% block title %}Candidatures - Espace pilote{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pilot-dashboard.css">
{% endblock %}

{% block body %}
<main class="pilot-page">
    <div class="pilot-container">
        <section class="activity-section">
            <div class="activity-header">
                <h2>Suivi des candidatures</h2>
                <a href="/espace-pilote">Retour au dashboard</a>
            </div>

            <div class="student-list">
                {% for application in applications %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ application.titre }}</h3>
                            <p>
                                {{ application.prenom }} {{ application.nom }}
                                • {{ application.email }}
                            </p>
                            <small>Déposée le {{ application.created_at|date('d/m/Y') }}</small>
                        </div>

                        <div class="student-actions student-actions-vertical">
                            {% if application.status == 'envoyee' %}
                                <span class="badge badge-blue">Envoyée</span>
                            {% elseif application.status == 'en_etude' %}
                                <span class="badge badge-yellow">En étude</span>
                            {% elseif application.status == 'acceptee' %}
                                <span class="badge badge-green">Acceptée</span>
                            {% elseif application.status == 'refusee' %}
                                <span class="badge badge-red">Refusée</span>
                            {% else %}
                                <span class="badge">{{ application.status }}</span>
                            {% endif %}

                            <form method="POST" action="/pilot-candidature/{{ application.id }}/status" class="application-status-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                                <select name="status" class="application-status-select">
                                    <option value="envoyee" {% if application.status == 'envoyee' %}selected{% endif %}>Envoyée</option>
                                    <option value="en_etude" {% if application.status == 'en_etude' %}selected{% endif %}>En étude</option>
                                    <option value="acceptee" {% if application.status == 'acceptee' %}selected{% endif %}>Acceptée</option>
                                    <option value="refusee" {% if application.status == 'refusee' %}selected{% endif %}>Refusée</option>
                                </select>

                                <button type="submit" class="student-button">
                                    Mettre à jour
                                </button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    <p class="empty-state">Aucune candidature trouvée.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</main>
{% endblock %}