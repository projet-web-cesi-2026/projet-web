{% extends 'base.html.twig' %}

{% block title %}Espace pilote{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/pilot-dashboard.css">
{% endblock %}

{% block body %}
<main class="pilot-page">
    <div class="pilot-container">
        <div class="pilot-header">
            <h1>Tableau de bord Pilote</h1>
            <p>Vue d’ensemble de la promotion</p>
        </div>

        <section class="stats-grid">
            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ total_students }}</strong>
                    <span>Étudiants au total</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ students_without_stage }}</strong>
                    <span>Étudiants sans stage</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ applications_count }}</strong>
                    <span>Candidatures envoyées</span>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-content">
                    <strong>{{ validated_stages }}</strong>
                    <span>Stages validés</span>
                </div>
            </article>
        </section>

        <section class="quick-actions">
            <article class="action-card">
                <h3>Gérer les étudiants</h3>
                <p>Consulter la liste complète et suivre leur progression</p>
                <a href="/pilot-etudiants" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Gestion des entreprises</h3>
                <p>Créer, modifier, évaluer, supprimer et consulter les entreprises.</p>
                <a href="/admin-entreprises" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Voir les offres</h3>
                <p>Parcourir toutes les offres de stage disponibles</p>
                <a href="/pilot-offres" class="student-button">Accéder</a>
            </article>

            <article class="action-card">
                <h3>Suivre les candidatures</h3>
                <p>Voir toutes les candidatures de la promotion</p>
                <a href="/pilot-candidatures" class="student-button">Accéder</a>
            </article>
        </section>

        <section class="activity-section">
            <div class="activity-header">
                <h2>Activité récente des étudiants</h2>
                <a href="/pilot-etudiants">Voir tous les étudiants</a>
            </div>

            <div class="student-list">
                {% for student in recent_students %}
                    <article class="student-row">
                        <div class="student-main">
                            <h3>{{ student.prenom }} {{ student.nom }}</h3>
                            <p>
                                {% if student.promotion_label and student.formation and student.promotion_label != student.formation %}
                                    {{ student.promotion_label }} • {{ student.formation }} • {{ student.email }}
                                {% elseif student.promotion_label %}
                                    {{ student.promotion_label }} • {{ student.email }}
                                {% elseif student.formation %}
                                    {{ student.formation }} • {{ student.email }}
                                {% else %}
                                    Promotion non définie • {{ student.email }}
                                {% endif %}
                            </p>

                            <div class="student-meta">
                                {% if student.status == 'sans_stage' %}
                                    <span class="badge badge-red">Sans stage</span>
                                {% elseif student.status == 'en_recherche' %}
                                    <span class="badge badge-yellow">En recherche</span>
                                {% elseif student.status == 'stage_trouve' %}
                                    <span class="badge badge-blue">Stage trouvé</span>
                                {% elseif student.status == 'stage_valide' %}
                                    <span class="badge badge-green">Stage validé</span>
                                {% endif %}

                                <small>Dernière activité : {{ student.last_activity|date('d/m/Y') }}</small>
                            </div>
                        </div>

                        <div class="student-actions">
                            <a href="/pilot-etudiants/{{ student.id }}" class="student-button">Voir le dossier</a>
                        </div>
                    </article>
                {% else %}
                    <p class="empty-state">Aucun étudiant trouvé.</p>
                {% endfor %}
            </div>
        </section>
    </div>
</main>
{% endblock %}