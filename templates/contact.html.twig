{% extends 'base.html.twig' %}

{% block title %}Contact - Help Me Stage{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/css/static-pages.css">
{% endblock %}

{% block body %}
<main class="legal-page">
    <div class="legal-container">
        <section class="legal-card">
            <h1>Contact</h1>

            <p>
                Une question concernant la plateforme Help Me Stage ? Un besoin d’assistance pour votre
                candidature ou votre suivi de stage ? Vous pouvez nous contacter via les informations ci-dessous.
            </p>

            <h2>Coordonnées</h2>
            <p>
                <strong>Email :</strong> contact@helpmestage.fr<br>
                <strong>Téléphone :</strong> 01 23 45 67 89<br>
                <strong>Adresse :</strong> 12 rue de l’Innovation, 75000 Paris
            </p>

            <h2>Horaires de disponibilité</h2>
            <p>
                Notre équipe est disponible du lundi au vendredi de 9h00 à 18h00.
            </p>

            <h2>Support étudiant</h2>
            <p>
                Si vous êtes étudiant, vous pouvez nous contacter pour :
            </p>
            <ul>
                <li>des questions sur votre compte ;</li>
                <li>un problème lors d’une candidature ;</li>
                <li>une difficulté d’accès à votre espace étudiant ;</li>
                <li>une demande liée au dépôt de CV ou à la lettre de motivation.</li>
            </ul>

            <h2>Support pilote / administration</h2>
            <p>
                Si vous êtes pilote de formation, vous pouvez nous contacter pour :
            </p>
            <ul>
                <li>la gestion des étudiants ;</li>
                <li>le suivi des candidatures ;</li>
                <li>l’administration des offres ;</li>
                <li>les incidents techniques sur le tableau de bord.</li>
            </ul>

            <h2>Délai de réponse</h2>
            <p>
                Nous nous efforçons de répondre à toutes les demandes sous 48 heures ouvrées.
            </p>

            <div class="legal-footer-link">
                <a href="/">← Retour à l’accueil</a>
            </div>
        </section>
    </div>
</main>
{% endblock %}